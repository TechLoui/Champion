rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    /* Imagens públicas do blog (leitura aberta; upload exige sessão Firebase) */
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /* Imagens de produtos e banners (leitura aberta; upload exige sessão) */
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /* Uploads diversos (PDFs, fichas técnicas) */
    match /uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /* Fallback nega tudo */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
